# Copy to .env and fill in. NEVER commit .env.
# ---- Core ----
FINOS_ENV=dev
FINOS_LOG_LEVEL=INFO
FINOS_API_HOST=0.0.0.0
FINOS_API_PORT=8000
# Comma-separated allowed CORS origins (mobile uses native, web/dev tools may need this)
FINOS_CORS_ORIGINS=http://localhost:3000

# ---- Postgres ----
POSTGRES_USER=finos
POSTGRES_PASSWORD=finos_dev_password_change_me
POSTGRES_DB=finos
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Async SQLAlchemy URL (asyncpg). Built from the above in config, override if needed.
FINOS_DATABASE_URL=postgresql+asyncpg://finos:finos_dev_password_change_me@localhost:5432/finos

# ---- Redis (Celery broker + cache) ----
FINOS_REDIS_URL=redis://localhost:6379/0

# ---- MinIO (S3-compatible object storage) ----
MINIO_ROOT_USER=finos
MINIO_ROOT_PASSWORD=finos_dev_password_change_me
FINOS_S3_ENDPOINT=http://localhost:9000
FINOS_S3_BUCKET=finos-attachments
FINOS_S3_ACCESS_KEY=finos
FINOS_S3_SECRET_KEY=finos_dev_password_change_me

# ---- Supabase Auth (identity provider only) ----
# The API verifies JWTs against Supabase's JWKS. Data stays in OUR Postgres.
FINOS_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
FINOS_SUPABASE_JWKS_URL=https://YOUR-PROJECT.supabase.co/auth/v1/.well-known/jwks.json
FINOS_JWT_AUDIENCE=authenticated
# Dev-only escape hatch: when true, auth is bypassed with a fake user (NEVER in prod).
FINOS_AUTH_DEV_BYPASS=true

# ---- AI (optional; app works fully without it) ----
FINOS_AI_ENABLED=false
FINOS_AI_PROVIDER=anthropic
FINOS_ANTHROPIC_API_KEY=
FINOS_OPENAI_API_KEY=
# Per-user monthly AI spend cap in minor units (e.g. paise). 0 disables AI.
FINOS_AI_MONTHLY_BUDGET_MINOR=0
